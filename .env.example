# ── Supabase ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-publishable-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # server only — never ship to the client

# ── Stripe ──────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_PRICE_STARTER=price_xxx
STRIPE_PRICE_SCHOOL=price_xxx

# ── App ─────────────────────────────────────────────────────────────────────
# Root domain used for tenant subdomains, e.g. {slug}.quizarena.app
NEXT_PUBLIC_ROOT_DOMAIN=quizarena.app
NEXT_PUBLIC_APP_URL=http://localhost:3000
