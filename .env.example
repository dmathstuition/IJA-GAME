# ── Supabase ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-publishable-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # server only — never ship to the client

# ── PayPal (one-time activation checkout) ────────────────────────────────────
# Create a REST app at https://developer.paypal.com/dashboard/applications
PAYPAL_ENV=sandbox                      # sandbox | live
PAYPAL_CLIENT_ID=your-paypal-client-id
PAYPAL_CLIENT_SECRET=your-paypal-secret
NEXT_PUBLIC_PAYPAL_CURRENCY=USD

# ── App ─────────────────────────────────────────────────────────────────────
# Root domain used for tenant subdomains, e.g. {slug}.quizarena.app
NEXT_PUBLIC_ROOT_DOMAIN=quizarena.app
NEXT_PUBLIC_APP_URL=http://localhost:3000
